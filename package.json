{
  "name": "@nasti-toolchain/plugin-tanstack",
  "version": "1.0.2",
  "description": "TanStack Router support for Nasti — file-based route tree generation + build-time automatic code splitting",
  "keywords": [
    "Nasti",
    "TanStack",
    "tanstack-router",
    "file-based-routing",
    "code-splitting",
    "rolldown"
  ],
  "homepage": "https://github.com/zixiao-labs/nasti-tanstack-plugin#readme",
  "bugs": {
    "url": "https://github.com/zixiao-labs/nasti-tanstack-plugin/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zixiao-labs/nasti-tanstack-plugin.git"
  },
  "license": "MIT",
  "author": "zixiao-labs",
  "type": "module",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "dependencies": {
    "@tanstack/router-generator": "^1.167.0",
    "oxc-parser": "^0.121.0",
    "oxc-transform": "^0.121.0",
    "picocolors": "^1.1.0"
  },
  "peerDependencies": {
    "@nasti-toolchain/nasti": ">=1.7.0",
    "@tanstack/react-router": ">=1.110.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
